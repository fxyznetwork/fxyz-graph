{
	"name": "@fxyz/graph-engine",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"description": "Graph-engine — the headless graph controller. Incremental ingest→diff→apply, server-positions-first layout policy, id-keyed identity/selection stores, throttled spatial-index interaction, budgeted labels, a lens runtime with incremental styling deltas, and renderers as swappable BACKENDS behind an observable-API contract (a stub backend ships in this package; a rendering-library adapter is wired via an injected constructor; other renderers slot in the same way). A suite of interaction-invariant acceptance tests ships in this package — features come after invariants.",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist/**"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./react": {
			"types": "./dist/react/index.d.ts",
			"import": "./dist/react/index.js",
			"require": "./dist/react/index.cjs"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist",
		"test": "jest --passWithNoTests"
	},
	"keywords": [
		"graph",
		"engine",
		"headless",
		"renderer",
		"backend",
		"lens"
	],
	"author": "fxyz network",
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fxyznetwork/fxyz-graph.git"
	},
	"homepage": "https://github.com/fxyznetwork/fxyz-graph/tree/main/packages/graph-engine#readme",
	"bugs": {
		"url": "https://github.com/fxyznetwork/fxyz-graph/issues"
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@fxyz/graph-contract": "workspace:*"
	},
	"peerDependencies": {
		"react": "^19.2.6"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@swc/core": "^1.15.40",
		"@swc/jest": "^0.2.39",
		"@types/jest": "^30.0.0",
		"@types/node": "^22",
		"@types/react": "^19.2.15",
		"jest": "^30.4.2",
		"tsup": "^8.5.1",
		"typescript": "^7.0.2"
	}
}
