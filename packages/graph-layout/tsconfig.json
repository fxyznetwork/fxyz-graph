{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"rootDir": "../..",
		"outDir": "dist",
		"target": "ES2020",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"moduleResolution": "bundler"
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"src/component/_archive/**"
	]
}
